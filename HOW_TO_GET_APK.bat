@echo off
title APK kaise milegi - GitHub se
color 0B

echo.
echo ╔══════════════════════════════════════════════════════╗
echo ║     APK kaise milegi - Step by Step Guide           ║
echo ╚══════════════════════════════════════════════════════╝
echo.
echo Flutter install kiye bina bhi APK ban sakti hai!
echo GitHub use karke CLOUD mein build hogi - FREE!
echo.
echo ══════════════════════════════════════════════════════
echo STEP 1: GitHub Account Banao (FREE)
echo ══════════════════════════════════════════════════════
echo.
echo  1. https://github.com kholein
echo  2. "Sign up" click karein
echo  3. Free account banao
echo.

echo ══════════════════════════════════════════════════════
echo STEP 2: GitHub Desktop Install Karo (Easiest)
echo ══════════════════════════════════════════════════════
echo.
echo  https://desktop.github.com download karein
echo  Install karein, GitHub account se login karein
echo.

echo ══════════════════════════════════════════════════════
echo STEP 3: Repository Banao
echo ══════════════════════════════════════════════════════
echo.
echo  1. GitHub Desktop kholein
echo  2. "Create New Repository" click karein
echo  3. Name: pdf_pro_reader
echo  4. Local Path: %~dp0
echo  5. "Create Repository" click karein
echo  6. "Publish Repository" click karein
echo  7. "Keep this code private" UNCHECKED rakhein (free build ke liye)
echo.

echo ══════════════════════════════════════════════════════
echo STEP 4: Code Upload Karo
echo ══════════════════════════════════════════════════════
echo.
echo  1. GitHub Desktop mein "Changes" tab kholein
echo  2. Sab files check honi chahiye
echo  3. Commit message: "Initial commit"
echo  4. "Commit to main" click karein
echo  5. "Push origin" click karein
echo.

echo ══════════════════════════════════════════════════════
echo STEP 5: APK Build Dekho
echo ══════════════════════════════════════════════════════
echo.
echo  1. github.com par apni repository kholein
echo  2. "Actions" tab click karein
echo  3. "Build APK (Android)" workflow dikhega
echo  4. Click karein - progress dekho
echo  5. 10-15 minute mein BUILD COMPLETE hoga
echo  6. "PDFProReader-APK" artifact download karein
echo  7. Unzip karein - app-release.apk milegi!
echo.

echo ══════════════════════════════════════════════════════
echo STEP 6: Mobile Par Install Karo
echo ══════════════════════════════════════════════════════
echo.
echo  1. APK file apne mobile par copy karein
echo     (WhatsApp, USB cable, ya Google Drive)
echo  2. Mobile par Settings kholein
echo  3. Security / Privacy > Unknown Sources ON karein
echo     (ya "Install Unknown Apps" allow karein)
echo  4. APK file tap karein - Install karein
echo  5. App kholein - TEST KAREIN!
echo.

echo ══════════════════════════════════════════════════════
echo WEBSITES AB KHUL RAHE HAIN...
echo ══════════════════════════════════════════════════════

start https://github.com
start https://desktop.github.com

echo.
pause
